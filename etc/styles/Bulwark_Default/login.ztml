<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>Control Panel - Login</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="robots" content="noindex, nofollow">
        <link href="/etc/styles/Bulwark_Default/global-css/bootstrap.min.css" rel="stylesheet">
        <link href="/etc/styles/Bulwark_Default/global-css/bootstrap-icons.min.css" rel="stylesheet">
        <link href="/etc/styles/Bulwark_Default/global-css/login.css" rel="stylesheet">
        <link rel="icon" href="/etc/styles/Bulwark_Default/img/ico/fav32.png" type="image/png">
        <!-- Anti-ClickJacking -->
        <style id="antiClickjack">body{display:none !important;}</style>
        <script>
            if (self === top) {
                document.getElementById("antiClickjack").parentNode.removeChild(document.getElementById("antiClickjack"));
            } else { top.location = self.location; }
        </script>
    </head>
    <body class="login-bg d-flex align-items-center justify-content-center min-vh-100">

        <div class="login-wrapper">

            <!-- Logo -->
            <div class="text-center mb-4">
                <img src="/etc/styles/Bulwark_Default/img/logos/bulwark_logo.png" alt="Bulwark" class="login-logo">
            </div>

            <!-- Card -->
            <div class="card shadow-sm login-card">
                <div class="card-body p-4">

                    <!-- Alertas -->
                    <?php if (isset($_GET['invalidlogin'])): ?>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i> Usuario o contraseña incorrectos.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <?php endif; ?>
                    <?php if (isset($_GET['loggedout'])): ?>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-1"></i> Sesión cerrada correctamente.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <?php endif; ?>
                    <?php if (isset($_GET['sessionIssue'])): ?>
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-1"></i> Sesión expirada. Inicia sesión de nuevo.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <?php endif; ?>
                    <?php if (isset($_GET['passwordreset'])): ?>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-1"></i> Contraseña restablecida.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <?php endif; ?>

                    <?php if (isset($_GET['resetkey']) && ctype_alnum($_GET['resetkey'])): ?>
                    <!-- Formulario restablecer contraseña -->
                    <h5 class="card-title mb-3">Restablecer contraseña</h5>
                    <div id="msgMatchErr" class="alert alert-danger" style="display:none">Las contraseñas no coinciden.</div>
                    <form action="?resetkey=<?php echo htmlspecialchars($_GET['resetkey']); ?>" method="post" id="frmZConfirm">
                        <div class="mb-3">
                            <label for="inputNewPass1" class="form-label">Nueva contraseña</label>
                            <input type="password" class="form-control" id="inputNewPass1" name="inNewPass" placeholder="Nueva contraseña" required>
                        </div>
                        <div class="mb-3">
                            <label for="inputNewPass2" class="form-label">Confirmar contraseña</label>
                            <input type="password" class="form-control" id="inputNewPass2" name="inputNewPass2" placeholder="Confirmar contraseña" required>
                        </div>
                        <div class="mb-3">
                            <label for="inConfEmail" class="form-label">Email</label>
                            <input type="email" class="form-control" id="inConfEmail" name="inConfEmail" placeholder="Email" required>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Restablecer</button>
                        </div>
                        <?php echo runtime_csfr::Token(); ?>
                    </form>

                    <?php else: ?>
                    <!-- Formulario olvidé contraseña (oculto) -->
                    <form method="post" id="frmZForgot" style="display:none">
                        <h5 class="card-title mb-3">Recuperar contraseña</h5>
                        <p class="text-muted small mb-3">Introduce tu email y recibirás un enlace de recuperación.</p>
                        <div class="mb-3">
                            <label for="inputEmail" class="form-label">Email</label>
                            <input type="email" class="form-control" id="inputEmail" name="inForgotPassword" placeholder="tu@email.com" required>
                        </div>
                        <div class="d-grid mb-2">
                            <button type="submit" class="btn btn-primary" name="sublogin2" value="LogIn">Enviar enlace</button>
                        </div>
                        <div class="text-center">
                            <a href="javascript:void(0);" id="backtologin" class="small text-muted">← Volver al login</a>
                        </div>
                        <?php echo runtime_csfr::Token(); ?>
                    </form>

                    <!-- Formulario login -->
                    <form method="post" id="frmZLogin">
                        <div class="mb-3">
                            <label for="inputUsername" class="form-label">Usuario</label>
                            <input type="text" class="form-control form-control-lg" id="inputUsername" name="inUsername" placeholder="Usuario" required autofocus>
                        </div>
                        <div class="mb-3">
                            <label for="inPassword" class="form-label">Contraseña</label>
                            <input type="password" class="form-control form-control-lg" id="inPassword" name="inPassword" placeholder="Contraseña" required>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="inRemember" value="1" id="chkRemember">
                                <label class="form-check-label small" for="chkRemember">Recordarme</label>
                            </div>
                            <a href="javascript:void(0);" id="forgotpw" class="small text-muted">¿Olvidaste la contraseña?</a>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="inSessionSecurity" value="1" id="chkSessionSecurity" checked>
                            <label class="form-check-label small" for="chkSessionSecurity">Seguridad de sesión <span class="text-muted">(ligar la sesión a mi IP y navegador; desmárcalo si usas proxy o IP variable)</span></label>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" name="sublogin2" value="LogIn">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar sesión
                            </button>
                        </div>
                        <?php echo runtime_csfr::Token(); ?>
                    </form>
                    <?php endif; ?>

                </div><!-- /card-body -->
            </div><!-- /card -->

            <p class="text-center text-muted small mt-3">
                Powered by Bulwark
            </p>
        </div><!-- /login-wrapper -->

        <script src="/etc/styles/Bulwark_Default/js/jquery.js"></script>
        <script src="/etc/styles/Bulwark_Default/js/bootstrap.bundle.min.js"></script>
        <script>
            $('#forgotpw').on('click', function() {
                $('#frmZLogin').slideUp('fast', function() { $('#frmZForgot').slideDown('fast'); });
            });
            $('#backtologin').on('click', function() {
                $('#frmZForgot').slideUp('fast', function() { $('#frmZLogin').slideDown('fast'); });
            });
            <?php if (isset($_GET['resetkey']) && ctype_alnum($_GET['resetkey'])): ?>
            $('#frmZConfirm').on('submit', function() {
                if ($('#inputNewPass1').val() !== $('#inputNewPass2').val() || !$('#inputNewPass1').val()) {
                    $('#msgMatchErr').show(); return false;
                }
                $('#msgMatchErr').hide(); return true;
            });
            <?php endif; ?>
        </script>
    </body>
</html>
